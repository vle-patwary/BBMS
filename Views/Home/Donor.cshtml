@{
    ViewData["Title"] = "Donor Dashboard";
}

<style>

    body {
        font-family: 'Segoe UI',sans-serif;
        background: #f4f6f9;
    }

    /* Dashboard Container */

    .dashboard {
        width: 90%;
        margin: auto;
        margin-top: 40px;
    }

    /* Header */

    .header {
        background: #b30000;
        color: white;
        padding: 20px;
        border-radius: 8px;
    }

        .header h2 {
            margin: 0;
        }

    /* Action Cards */

    .actions {
        display: flex;
        gap: 20px;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .card {
        flex: 1;
        min-width: 200px;
        background: white;
        padding: 25px;
        border-radius: 10px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

        .card a {
            text-decoration: none;
            color: #b30000;
            font-weight: bold;
            font-size: 18px;
        }

    /* Table Section */

    .table-section {
        margin-top: 40px;
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 12px;
        border-bottom: 1px solid #ddd;
    }

    th {
        background: #b30000;
        color: white;
    }

</style>


<div class="dashboard">

    <div class="header">
        <h2>Welcome, Donor Name</h2>
    </div>

    <!-- Action Buttons -->

    <div class="actions">

        <div class="card">
            <a asp-controller="Donation" asp-action="Create">Donate Blood</a>
        </div>

        <div class="card">
            <a asp-controller="Appointment" asp-action="Create">Appointment</a>
        </div>

        <div class="card">
            <a asp-controller="Donation" asp-action="History">Donation History</a>
        </div>

        <div class="card">
            <a asp-controller="Donor" asp-action="Profile">Update Profile</a>
        </div>

    </div>


    <!-- Recent Donations -->

    <div class="table-section">

        <h3>Recent Donations</h3>

        <table>

            <tr>
                <th>Date</th>
                <th>Blood Group</th>
                <th>Status</th>
            </tr>

            <tr>
                <td>10-03-2026</td>
                <td>O+</td>
                <td>Completed</td>
            </tr>

            <tr>
                <td>15-02-2026</td>
                <td>A+</td>
                <td>Completed</td>
            </tr>

        </table>

    </div>

</div>