@{
    ViewData["Title"] = "Donor Dashboard";
}

<style>

    body {
        font-family: 'Segoe UI',sans-serif;
        background: #f4f6f9;
    }

    /* Container */

    .dashboard {
        width: 90%;
        margin: auto;
        margin-top: 40px;
    }

    /* Header */

    .header {
        background: linear-gradient(135deg,#b30000,#ff4d4d);
        color: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    /* Cards */

    .card-container {
        display: flex;
        gap: 20px;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .card {
        flex: 1;
        min-width: 220px;
        background: white;
        padding: 25px;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        cursor: pointer;
    }

        /* Hover effect */

        .card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        /* Link style */

        .card a {
            text-decoration: none;
            color: #b30000;
            font-weight: bold;
            font-size: 18px;
            display: block;
        }

    /* Table */

    .table-section {
        margin-top: 30px;
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 14px;
        border-bottom: 1px solid #ddd;
    }

    th {
        background: #b30000;
        color: white;
    }

    tr:hover {
        background: #f9f9f9;
    }

</style>


<div class="dashboard">

    <!-- HEADER -->
    <div class="header">
        <h2>Welcome, Donor Name</h2>
    </div>


    <!-- ACTIONS -->

    <div class="card-container">

        <div class="card">
            <a asp-controller="Donation" asp-action="Create">🩸 Donate Blood</a>
        </div>

        <div class="card">
            <a asp-controller="Appointment" asp-action="Create">📅 Appointment</a>
        </div>

        <div class="card">
            <a asp-controller="Donation" asp-action="History">📊 Donation History</a>
        </div>

        <div class="card">
            <a asp-controller="Donor" asp-action="Profile">⚙️ Update Profile</a>
        </div>

    </div>


    <!-- TABLE -->

    <div class="table-section">

        <h3>Recent Donations</h3>

        <table>

            <tr>
                <th>Date</th>
                <th>Blood Group</th>
                <th>Status</th>
            </tr>

            <tr>
                <td>10-03-2026</td>
                <td>O+</td>
                <td>Completed</td>
            </tr>

            <tr>
                <td>15-02-2026</td>
                <td>A+</td>
                <td>Completed</td>
            </tr>

        </table>

    </div>

</div>