@{
    ViewData["Title"] = "Admin Dashboard";
}

<style>

    body {
        font-family: 'Segoe UI',sans-serif;
        background: #f4f6f9;
    }

    /* Container */

    .dashboard {
        width: 90%;
        margin: auto;
        margin-top: 40px;
    }

    /* Header */

    .header {
        background: linear-gradient(135deg,#b30000,#ff4d4d);
        color: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    /* Section Title */

    .section-title {
        margin-top: 35px;
        margin-bottom: 15px;
        color: #b30000;
        font-weight: 600;
    }

    /* Cards */

    .card-container {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
    }

    .card {
        flex: 1;
        min-width: 220px;
        background: white;
        padding: 25px;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        cursor: pointer;
    }

        /* Hover Effect */

        .card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        /* Link style */

        .card a {
            text-decoration: none;
            color: #b30000;
            font-weight: bold;
            font-size: 18px;
            display: block;
        }

    /* Table */

    .table-section {
        margin-top: 30px;
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 14px;
        border-bottom: 1px solid #ddd;
    }

    th {
        background: #b30000;
        color: white;
    }

    tr:hover {
        background: #f9f9f9;
    }

</style>


<div class="dashboard">

    <!-- HEADER -->
    <div class="header">
        <h2>Admin Dashboard</h2>
        <p>Manage System, Blood Stock & Requests</p>
    </div>


    <!-- MANAGEMENT SECTION -->
    <h3 class="section-title">System Management</h3>

    <div class="card-container">

        <div class="card">
            <a asp-controller="Donor" asp-action="List">👤 Manage Donors</a>
        </div>

        <div class="card">
            <a asp-controller="Staff" asp-action="List">👨‍⚕️ Manage Staff</a>
        </div>

        <div class="card">
            <a asp-controller="Hospital" asp-action="List">🏥 Manage Hospitals</a>
        </div>

    </div>


    <!-- BLOOD MANAGEMENT -->
    <h3 class="section-title">Blood Management</h3>

    <div class="card-container">

        <div class="card">
            <a asp-controller="Stock" asp-action="Index">🩸 Manage Blood Stock</a>
        </div>

        <div class="card">
            <a asp-controller="Request" asp-action="List">📋 Blood Requests</a>
        </div>

        <div class="card">
            <a asp-controller="Report" asp-action="Index">📊 Generate Reports</a>
        </div>

    </div>


    <!-- SUMMARY TABLE -->

    <div class="table-section">

        <h3>Blood Stock Summary</h3>

        <table>

            <tr>
                <th>Blood Group</th>
                <th>Available Units</th>
            </tr>

            <tr>
                <td>A+</td>
                <td>15</td>
            </tr>

            <tr>
                <td>B+</td>
                <td>12</td>
            </tr>

            <tr>
                <td>O+</td>
                <td>20</td>
            </tr>

            <tr>
                <td>AB+</td>
                <td>5</td>
            </tr>

        </table>

    </div>

</div>