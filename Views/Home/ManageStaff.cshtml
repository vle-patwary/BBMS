@{
    ViewData["Title"] = "Manage Staff";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

    body {
        font-family: 'Segoe UI',sans-serif;
        background: #f4f6f9;
    }

    .dashboard {
        width: 90%;
        margin: auto;
        margin-top: 40px;
    }

    .page-header {
        background: linear-gradient(135deg, #b30000, #ff4d4d);
        color: white;
        padding: 20px 28px;
        border-radius: 12px;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .page-header h2 {
            margin: 0 0 4px 0;
            font-size: 22px;
        }

        .page-header p {
            margin: 0;
            font-size: 14px;
            opacity: 0.9;
        }

    .btn {
        padding: 10px 22px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-size: 14px;
        font-family: inherit;
        text-decoration: none;
        display: inline-block;
    }

    .btn-primary {
        background: white;
        color: #b30000;
        font-weight: 600;
    }

        .btn-primary:hover {
            background: #ffe0e0;
        }

    .btn-back {
        background: #ccc;
        color: #333;
    }

        .btn-back:hover {
            background: #bbb;
        }

    .btn-export {
        background: #2e7d32;
        color: white;
        font-weight: 600;
    }

        .btn-export:hover {
            background: #388e3c;
        }

    /* TABLE */
    .table-section {
        margin-top: 30px;
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 14px;
        border-bottom: 1px solid #ddd;
        text-align: left;
    }

    th {
        background: #b30000;
        color: white;
    }

    tr:hover {
        background: #f9f9f9;
    }

    /* ACTION BUTTONS */
    .action-btn {
        padding: 6px 10px;
        border-radius: 5px;
        text-decoration: none;
        font-size: 13px;
        margin-right: 5px;
    }

    .edit {
        background: #007bff;
        color: white;
    }

    .delete {
        background: #b30000;
        color: white;
    }

</style>

<div class="dashboard">

   
    <!-- Page Header -->
    <div class="page-header">
        <div>
            <h2>Manage Staff</h2>
            <p>View, register, and manage all blood donors in the system</p>
        </div>
        <div style="display:flex; gap:10px;">
            <a asp-controller="Home" asp-action="AddCollection" class="btn btn-primary">+ Add New Staff</a>
            <a asp-controller="Home" asp-action="Admin" class="btn btn-back">&#8592; Back</a>
        </div>
    </div>

    <!-- TABLE -->
    <div class="table-section">

        <h3>Staff List</h3>

        <table>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Contact</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>

            <tr>
                <td>Rahim</td>
                <td>rahim@gmail.com</td>
                <td>017XXXXXXXX</td>
                <td>Staff</td>
                <td>
                    <a href="#" class="action-btn edit">
                        <i class="fa-solid fa-pen"></i> Edit
                    </a>
                    <a href="#" class="action-btn delete">
                        <i class="fa-solid fa-trash"></i> Delete
                    </a>
                </td>
            </tr>

            <tr>
                <td>Karim</td>
                <td>karim@gmail.com</td>
                <td>018XXXXXXXX</td>
                <td>Staff</td>
                <td>
                    <a href="#" class="action-btn edit">
                        <i class="fa-solid fa-pen"></i> Edit
                    </a>
                    <a href="#" class="action-btn delete">
                        <i class="fa-solid fa-trash"></i> Delete
                    </a>
                </td>
            </tr>

        </table>

    </div>

</div>