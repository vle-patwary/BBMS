@{
    ViewData["Title"] = "Staff Dashboard";
}

<style>

    body {
        font-family: 'Segoe UI',sans-serif;
        background: #f4f6f9;
    }

    /* Container */

    .dashboard {
        width: 90%;
        margin: auto;
        margin-top: 40px;
    }

    /* Header */

    .header {
        background: #222;
        color: white;
        padding: 20px;
        border-radius: 8px;
    }

        .header h2 {
            margin: 0;
        }

    /* Action Cards */

    .actions {
        display: flex;
        gap: 20px;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .card {
        flex: 1;
        min-width: 220px;
        background: white;
        padding: 25px;
        border-radius: 10px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-5px);
        }

        .card a {
            text-decoration: none;
            color: #b30000;
            font-weight: bold;
            font-size: 18px;
        }

    /* Table Section */

    .table-section {
        margin-top: 40px;
        background: white;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 12px;
        border-bottom: 1px solid #ddd;
    }

    th {
        background: #b30000;
        color: white;
    }

</style>


<div class="dashboard">

    <!-- Header -->
    <div class="header">
        <h2>Staff Dashboard</h2>
    </div>

    <!-- Actions -->
    <div class="actions">

        <div class="card">
            <a asp-controller="BloodCollection" asp-action="Create">Add Blood Collection</a>
        </div>

        <div class="card">
            <a asp-controller="BloodTest" asp-action="Create">Test Blood</a>
        </div>

        <div class="card">
            <a asp-controller="Donation" asp-action="Create">Record Blood Donation</a>
        </div>

    </div>


    <!-- Recent Donations -->
    <div class="table-section">

        <h3>Recent Blood Donations</h3>

        <table>

            <tr>
                <th>Donor Name</th>
                <th>Blood Group</th>
                <th>Date</th>
            </tr>

            <tr>
                <td>Rahim</td>
                <td>O+</td>
                <td>12-03-2026</td>
            </tr>

            <tr>
                <td>Karim</td>
                <td>B+</td>
                <td>11-03-2026</td>
            </tr>

        </table>

    </div>

</div>