@{
    ViewData["Title"] = "Home";
}
<style>
    * {
        box-sizing: border-box;
    }

    /* Hero */
    .hero {
        background: #8b0000;
        padding: 60px 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        gap: 24px;
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: '';
            position: absolute;
            right: -60px;
            top: -60px;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
        }

        .hero::after {
            content: '';
            position: absolute;
            left: -80px;
            bottom: -80px;
            width: 260px;
            height: 260px;
            border-radius: 50%;
            background: rgba(255,255,255,0.04);
        }

        .hero h1 {
            font-size: 36px;
            font-weight: 700;
            color: #ffffff;
            white-space: nowrap;
            z-index: 1;
        }

        .hero p {
            font-size: 15px;
            color: #ffb3b3;
            z-index: 1;
        }

    .hero-stats {
        display: flex;
        align-items: center;
        gap: 16px;
        z-index: 1;
    }

    .stat-box {
        text-align: center;
    }

        .stat-box .num {
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            line-height: 1;
        }

        .stat-box .lbl {
            font-size: 11px;
            color: #ffb3b3;
            margin-top: 4px;
            letter-spacing: 0.5px;
        }

    .hero-divider {
        width: 1px;
        height: 50px;
        background: rgba(255,255,255,0.2);
    }

    .hero-btns {
        display: flex;
        gap: 12px;
        z-index: 1;
    }

    .btn-donate, .btn-request {
        padding: 11px 28px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        border: 2px solid transparent;
        white-space: nowrap;
    }

    .btn-donate {
        background: white;
        color: #8b0000;
    }

        .btn-donate:hover {
            background: #ffe5e5;
        }

    .btn-request {
        background: transparent;
        color: white;
        border-color: rgba(255,255,255,0.5);
    }

        .btn-request:hover {
            background: rgba(255,255,255,0.1);
        }

    /* Section */
    .section {
        padding: 50px 40px;
        text-align: center;
    }

        .section h2 {
            font-size: 24px;
            font-weight: 700;
            color: #1a1a1a;
            margin-bottom: 30px;
            display: inline-block;
        }

            .section h2::after {
                content: '';
                display: block;
                width: 40px;
                height: 3px;
                background: #8b0000;
                border-radius: 2px;
                margin: 8px auto 0;
            }

    /* Cards */
    .card-container {
        display: flex;
        justify-content: center;
        gap: 24px;
        flex-wrap: wrap;
    }

    .card {
        background: white;
        padding: 26px 20px;
        border-radius: 10px;
        width: 210px;
        border: 1px solid #f0e0e0;
        border-top: 4px solid #8b0000;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 24px rgba(139,0,0,0.1);
        }

        .card h3 {
            color: #8b0000;
            font-size: 15px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .card p {
            font-size: 13px;
            color: #555;
            line-height: 1.6;
        }

    /* Table */
    .table-section {
        background: white;
        border-top: 1px solid #f0e0e0;
        border-bottom: 1px solid #f0e0e0;
    }

    table {
        margin: 0 auto;
        border-collapse: collapse;
        width: 460px;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #f0dede;
    }

    th {
        background: #8b0000;
        color: white;
        padding: 12px 20px;
        font-size: 14px;
        font-weight: 600;
        text-align: left;
    }

    td {
        padding: 11px 20px;
        border-bottom: 1px solid #f5eded;
        font-size: 14px;
        color: #333;
        text-align: left;
    }

    tr:last-child td {
        border-bottom: none;
    }

    tr:nth-child(even) td {
        background: #fff8f8;
    }

    .unit-badge {
        display: inline-block;
        background: #fff0f0;
        color: #8b0000;
        font-weight: 600;
        font-size: 13px;
        padding: 3px 10px;
        border-radius: 20px;
    }
</style>

<!-- HERO -->
<div class="hero">
    <h1>Blood Bank Management System</h1>
    <p>Donate Blood &mdash; Save Lives</p>
    <div class="hero-stats">
        <div class="stat-box"><div class="num">50+</div><div class="lbl">Donors</div></div>
        <div class="hero-divider"></div>
        <div class="stat-box"><div class="num">200+</div><div class="lbl">Lives Saved</div></div>
        <div class="hero-divider"></div>
        <div class="stat-box"><div class="num">8</div><div class="lbl">Blood Groups</div></div>
    </div>
    <div class="hero-btns">
        <a href="/Home/Donate" class="btn-donate">Donate Blood</a>
        <a href="/Home/Request" class="btn-request">Request Blood</a>
    </div>
</div>

<!-- SERVICES -->
<div class="section">
    <h2>Our Services</h2>
    <div class="card-container">
        <div class="card">
            <h3>Blood Donation</h3>
            <p>Register as a donor and help save lives by donating blood.</p>
        </div>
        <div class="card">
            <h3>Request Blood</h3>
            <p>Hospitals and patients can request blood quickly and easily.</p>
        </div>
        <div class="card">
            <h3>Track Requests</h3>
            <p>Check the status of your blood request in real time.</p>
        </div>
    </div>
</div>

<!-- BLOOD AVAILABILITY -->
<div class="section table-section">
    <h2>Blood Availability</h2>
    <table>
        <tr><th>Blood Group</th><th>Available Units</th></tr>
        <tr><td>A+</td><td><span class="unit-badge">15 units</span></td></tr>
        <tr><td>B+</td><td><span class="unit-badge">10 units</span></td></tr>
        <tr><td>O+</td><td><span class="unit-badge">20 units</span></td></tr>
        <tr><td>AB+</td><td><span class="unit-badge">5 units</span></td></tr>
    </table>
</div>