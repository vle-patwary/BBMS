@{
    ViewData["Title"] = "Donate Blood";
}

<style>

    body {
        font-family: 'Segoe UI',sans-serif;
        background: #f4f6f9;
    }

    /* Container */
    .donate-container {
        width: 420px;
        margin: 60px auto;
        background: white;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

        .donate-container h2 {
            text-align: center;
            color: #b30000;
            margin-bottom: 25px;
        }

    /* Form */
    .form-group {
        margin-bottom: 15px;
    }

    label {
        font-weight: 600;
    }

    input, select {
        width: 100%;
        padding: 10px;
        margin-top: 5px;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    /* Button */
    .btn-submit {
        width: 100%;
        background: #b30000;
        color: white;
        padding: 12px;
        border: none;
        border-radius: 6px;
        margin-top: 15px;
        font-size: 16px;
        cursor: pointer;
    }

        .btn-submit:hover {
            background: #ff3333;
        }

</style>

<div class="donate-container">

    <h2>Donate Blood</h2>

    <form asp-action="Create" asp-controller="Donation" method="post">

        <div class="form-group">
            <label>Donor Name</label>
            <input type="text" name="DonorName" required />
        </div>

        <div class="form-group">
            <label>Blood Group</label>
            <select name="BloodGroup" required>
                <option value="">-- Select Blood Group --</option>
                <option>A+</option>
                <option>A-</option>
                <option>B+</option>
                <option>B-</option>
                <option>O+</option>
                <option>O-</option>
                <option>AB+</option>
                <option>AB-</option>
            </select>
        </div>

        <div class="form-group">
            <label>Age</label>
            <input type="number" name="Age" min="18" required />
        </div>

        <div class="form-group">
            <label>Last Donation Date</label>
            <input type="date" name="LastDonationDate" />
        </div>

        <div class="form-group">
            <label>Contact Number</label>
            <input type="text" name="ContactNumber" required />
        </div>

        <button type="submit" class="btn-submit">Submit Donation</button>

    </form>

</div>