@{
    ViewData["Title"] = "Request Submitted";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

    body {
        font-family: 'Segoe UI', sans-serif;
        background: #f4f6f9;
    }

    .success-container {
        width: 420px;
        margin: 80px auto;
        background: white;
        padding: 35px;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    .icon {
        font-size: 60px;
        color: #b30000;
        margin-bottom: 15px;
    }

    h2 {
        color: #b30000;
        margin-bottom: 10px;
    }

    p {
        color: #555;
        font-size: 14px;
        margin-bottom: 20px;
    }

    .info-box {
        background: #fff5f5;
        border-left: 5px solid #b30000;
        padding: 15px;
        border-radius: 8px;
        text-align: left;
        margin-bottom: 20px;
    }

        .info-box span {
            display: block;
            font-size: 13px;
            margin-bottom: 5px;
        }

    .btn {
        display: inline-block;
        padding: 12px 18px;
        margin: 5px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-primary {
        background: #b30000;
        color: white;
    }

        .btn-primary:hover {
            background: #800000;
        }

    .btn-secondary {
        background: #ddd;
        color: #333;
    }

</style>

<div class="success-container">

    <i class="fa-solid fa-hand-holding-heart icon"></i>

    <h2>Request Submitted!</h2>

    <p>Your blood request has been successfully recorded. Our system will try to connect you with available donors as soon as possible.</p>

    <!-- Request Info -->
    <div class="info-box">
        <span><strong>Blood Group:</strong> O+</span>
        <span><strong>Location:</strong> Dhaka</span>
        <span><strong>Status:</strong> Pending</span>
    </div>

    <!-- Actions -->
    <a asp-controller="Home" asp-action="TrackRequest" class="btn btn-primary">
        Track Request
    </a>

    <a asp-controller="Home" asp-action="User" class="btn btn-secondary">
        Back to Dashboard
    </a>

</div>