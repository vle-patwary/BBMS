@{
    ViewData["Title"] = "Donation Success";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

    body {
        font-family: 'Segoe UI', sans-serif;
        background: #f4f6f9;
    }

    .success-container {
        width: 420px;
        margin: 80px auto;
        background: white;
        padding: 35px;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    .icon {
        font-size: 60px;
        color: green;
        margin-bottom: 15px;
    }

    h2 {
        color: #b30000;
        margin-bottom: 10px;
    }

    p {
        color: #555;
        font-size: 14px;
        margin-bottom: 20px;
    }

    .info-box {
        background: #e6f9ee;
        border-left: 5px solid green;
        padding: 15px;
        border-radius: 8px;
        text-align: left;
        margin-bottom: 20px;
    }

        .info-box span {
            display: block;
            font-size: 13px;
            margin-bottom: 5px;
        }

    .btn {
        display: inline-block;
        padding: 12px 18px;
        margin: 5px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-primary {
        background: #b30000;
        color: white;
    }

        .btn-primary:hover {
            background: #800000;
        }

    .btn-secondary {
        background: #ddd;
        color: #333;
    }

</style>

<div class="success-container">

    <i class="fa-solid fa-circle-check icon"></i>

    <h2>Donation Submitted Successfully!</h2>

    <p>
        Thank you for your willingness to donate blood.
        Your contribution can help save lives. Our team will contact you soon.
    </p>

    <!-- Optional Info -->
    <div class="info-box">
        <span><strong>Status:</strong> Registered</span>
        <span><strong>Next Step:</strong> Wait for confirmation call</span>
    </div>

    <!-- Buttons -->
    <a asp-controller="Home" asp-action="User" class="btn btn-primary">
        Back to Dashboard
    </a>

    <a asp-controller="Home" asp-action="Donate" class="btn btn-secondary">
        Donate Again
    </a>

</div>